@page "/datagrid"

<PageTitle>Data Grid</PageTitle>

<FluentText Size="TextSize.Size600" Weight="TextWeight.Bold" Margin="@Margin.Bottom4">
    Data Grid
</FluentText>

<FluentText Size="TextSize.Size300" Margin="@Margin.Bottom4"
            Color="Color.Custom" CustomColor="var(--colorNeutralForeground2)">
    Full-featured data grid with sorting, pagination, and template columns.
</FluentText>

<FluentCard>
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="16px">

        <FluentTextInput @bind-Value="_searchTerm"
                         Placeholder="Search employees..."
                         Style="max-width: 300px;"
                         @oninput="OnSearchChanged" />

        <FluentDataGrid Items="@FilteredEmployees"
                        Pagination="@_pagination"
                        GridTemplateColumns="0.3fr 1fr 1fr 0.8fr 0.6fr 0.5fr"
                        Style="width: 100%;">
            <PropertyColumn Property="@(e => e.Id)" Title="ID" Sortable="true" />
            <PropertyColumn Property="@(e => e.Name)" Title="Name" Sortable="true" />
            <PropertyColumn Property="@(e => e.Email)" Title="Email" Sortable="true" />
            <PropertyColumn Property="@(e => e.Department)" Title="Department" Sortable="true" />
            <PropertyColumn Property="@(e => e.Salary)" Title="Salary" Format="C0" Sortable="true" />
            <TemplateColumn Title="Actions">
                <FluentButton Appearance="ButtonAppearance.Subtle"
                              IconOnly="true"
                              IconStart="@(new Icons.Regular.Size20.Edit())"
                              OnClick="@(() => Edit(context))" />
            </TemplateColumn>
        </FluentDataGrid>

        <FluentPaginator State="@_pagination" />
    </FluentStack>
</FluentCard>

@code {
    private string _searchTerm = string.Empty;
    private PaginationState _pagination = new() { ItemsPerPage = 8 };

    private IQueryable<Employee> FilteredEmployees =>
        string.IsNullOrWhiteSpace(_searchTerm)
            ? _employees.AsQueryable()
            : _employees.Where(e =>
                e.Name.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
                e.Email.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
                e.Department.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase))
            .AsQueryable();

    private void OnSearchChanged(ChangeEventArgs e)
    {
        _searchTerm = e.Value?.ToString() ?? string.Empty;
    }

