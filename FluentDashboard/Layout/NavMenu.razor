<FluentNav Collapsible="true" Width="250" Style="height: 100%;">

    <FluentNavSectionHeader>Dashboard</FluentNavSectionHeader>

    <FluentNavItem Href="/"
                   Match="NavLinkMatch.All"
                   IconRest="@(new Icons.Regular.Size20.Home())"
                   IconActive="@(new Icons.Filled.Size20.Home())">
        Home
    </FluentNavItem>

    <FluentNavItem Href="/counter"
                   IconRest="@(new Icons.Regular.Size20.NumberSymbolSquare())"
                   IconActive="@(new Icons.Filled.Size20.NumberSymbolSquare())">
        Counter
    </FluentNavItem>

    <FluentNavItem Href="/weather"
                   IconRest="@(new Icons.Regular.Size20.WeatherSunny())"
                   IconActive="@(new Icons.Filled.Size20.WeatherSunny())">
        Weather
    </FluentNavItem>

    <FluentNavSectionHeader>Analytics</FluentNavSectionHeader>

    <FluentNavItem Href="/datagrid"
                   IconRest="@(new Icons.Regular.Size20.Table())"
                   IconActive="@(new Icons.Filled.Size20.Table())">
        Data Grid
    </FluentNavItem>

    <FluentNavItem Href="/settings"
                   IconRest="@(new Icons.Regular.Size20.Settings())"
                   IconActive="@(new Icons.Filled.Size20.Settings())">
        Settings
    </FluentNavItem>

</FluentNav>
